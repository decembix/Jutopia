HOST=127.0.0.1
PORT=4173
SESSION_SECRET=replace-with-a-long-random-secret
EMAIL_MODE=dev
APP_ORIGIN=*

# Default evaluator mode: no PostgreSQL required.
# Data is kept in memory and resets whenever server.py restarts.
JUTOPIA_DEV_NO_DB=true

# To test against PostgreSQL, set JUTOPIA_DEV_NO_DB=false and fill DATABASE_URL.
# DATABASE_URL=postgresql://jutopia_app:jutopia_dev_password@127.0.0.1:55432/jutopia_dev
# PGHOST=127.0.0.1
# PGPORT=55432
# PGDATABASE=jutopia_dev
# PGUSER=jutopia_app
# PGPASSWORD=jutopia_dev_password

# Real email sending: change EMAIL_MODE=smtp and fill these values.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true
